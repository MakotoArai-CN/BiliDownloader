    <!-- Agreement Dialog -->
    <string name="agreement_title">使用协议与隐私政策</string>
    <string name="accept">同意</string>
    <string name="decline">拒绝</string>
    <string name="welcome_title">欢迎使用 BiliDown</string>
    <string name="welcome_message">请仔细阅读以下协议。使用本应用即表示您同意以下条款：</string>
    <string name="agreement_confirm_hint">点击"同意"即表示您已阅读并同意以上所有条款</string>

    <string name="agreement_section_1_title">一、使用条款</string>
    <string name="agreement_section_1_content">1. 本应用仅供个人学习和研究使用，严禁用于商业用途。\n\n2.
        下载的视频内容版权归原创作者所有，请尊重知识产权。\n\n3. 用户不得将下载的视频用于：\n - 搬运至其他平台\n - 商业用途或牟利\n - 侵犯他人权益\n -
        其他违反法律法规的行为\n\n4. 本应用不对使用过程中产生的任何法律后果负责。\n\n5. 本应用保留随时修改本条款的权利。</string>

    <string name="agreement_section_2_title">二、隐私政策</string>
    <string name="agreement_section_2_content">1. 数据收集\n 本应用不会收集个人信息。所有操作均在本地完成。\n\n2. Cookie 使用\n
        您提供的 Cookie 存储在您的设备本地，仅用于访问 Bilibili API。\n\n3. 存储权限\n 应用需要存储权限来保存下载的视频文件。\n\n4. 网络权限\n
        应用需要网络权限来访问 Bilibili API 并下载内容。\n\n5. 数据安全\n 所有数据存储在您的本地设备上，不会上传至任何服务器。\n\n6. 第三方服务\n 本应用使用
        Bilibili 的公共 API。请同时遵守 Bilibili 的服务条款。</string>

    <string name="agreement_section_3_title">三、免责声明</string>
    <string name="agreement_section_3_content">1. 本应用按"现状"提供，不附带任何保证。\n\n2. 使用本应用的任何风险由用户自行承担。\n\n3.
        开发者不对任何直接或间接损失负责。\n\n4. 本应用仅供技术学习，请支持原创内容创作者。\n\n5. 如果您不同意这些条款，请立即停止使用本应用。</string>

