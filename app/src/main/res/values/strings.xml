    <!-- Agreement Dialog -->
    <string name="agreement_title">Terms of Service &amp; Privacy Policy</string>
    <string name="accept">Accept</string>
    <string name="decline">Decline</string>
    <string name="welcome_title">Welcome to BiliDown</string>
    <string name="welcome_message">Please read the following agreement carefully. By using this app,
        you agree to the following terms:</string>
    <string name="agreement_confirm_hint">By clicking \"Accept\", you have read and agreed to all
        terms above</string>

    <string name="agreement_section_1_title">1. Terms of Use</string>
    <string name="agreement_section_1_content">1. This app is for personal study and research only.
        Commercial use is strictly prohibited.\n\n2. The copyright of downloaded video content
        belongs to the original creators. Please respect intellectual property.\n\n3. Users must not
        use downloaded videos for:\n - Re-uploading to other platforms\n - Commercial use or
        profit\n - Infringing upon others\' rights\n - Other violations of law\n\n4. This app is not
        responsible for any legal consequences from usage.\n\n5. This app reserves the right to
        modify these terms at any time.</string>

    <string name="agreement_section_2_title">2. Privacy Policy</string>
    <string name="agreement_section_2_content">1. Data Collection\n This app does not collect
        personal information. All operations are performed locally.\n\n2. Cookie Usage\n Cookies you
        provide are stored locally on your device for accessing Bilibili API.\n\n3. Storage
        Permission\n The app requires storage permission to save downloaded video files.\n\n4.
        Network Permission\n The app requires network permission to access Bilibili API and download
        content.\n\n5. Data Security\n All data is stored on your local device. Nothing is uploaded
        to any server.\n\n6. Third-party Services\n This app uses Bilibili\'s public API. Please
        also comply with Bilibili\'s terms of service.</string>

    <string name="agreement_section_3_title">3. Disclaimer</string>
    <string name="agreement_section_3_content">1. This app is provided \"as is\" without any
        warranty.\n\n2. Any risks from using this app are borne by the user.\n\n3. The developer is
        not responsible for any direct or indirect losses.\n\n4. This app is for technical learning
        only. Please support original content creators.\n\n5. If you do not agree to these terms,
        please stop using this app immediately.</string>

